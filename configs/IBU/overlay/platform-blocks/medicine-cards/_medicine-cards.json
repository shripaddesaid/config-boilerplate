{
  "definitions": [
    {
      "title": "Medicine Cards",
      "id": "medicine-cards",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Medicine Cards",
              "model": "medicine-cards",
              "filter": "medicine-cards"
            }
          }
        }
      }
    }
  ],
  "filters": [
    {
      "id": "medicine-cards",
      "components": ["medicine-card-item"]
    }
  ],
  "models": [
    {
      "id": "medicine-cards",
      "fields": [
        {
          "component": "checkbox-group",
          "name": "classes_medicineFilter",
          "valueType": "string",
          "description": "Select this checkbox to display the medicine filter.",
          "options": [
            {
              "name": "Enable Medicine Filter",
              "value": "true"
            }
          ]
        },
        {
          "component": "checkbox-group",
          "name": "classes_conditionWiseGrouping",
          "valueType": "string",
          "description": "Select this checkbox to enable condition-wise grouping of the medicines.",
          "options": [
            {
              "name": "Enable Condition-wise grouping",
              "value": "true"
            }
          ]
        },
        {
          "component": "checkbox-group",
          "name": "classes_loadMoreButton",
          "valueType": "string",
          "description": "Select this checkbox to enable the “Load more medicines+” button.",
          "options": [
            {
              "name": "Enable Load More Button",
              "value": "true"
            }
          ]
        },
        {
          "component": "number",
          "label": "Number of Medicine Cards to be loaded",
          "name": "numberOfMedicineCardsToBeLoaded",
          "valueType": "number",
          "value": 12,
          "description": "Specify the number of medicine cards to be loaded by default if the Load more button is selected.",
          "condition": {
            "!!": {
              "var": "classes_loadMoreButton"
            }
          }
        }
      ]
    }
  ]
}
