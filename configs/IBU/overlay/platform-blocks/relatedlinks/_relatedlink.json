{
  "definitions": [
    {
      "title": "Relatedlink",
      "id": "relatedlink",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Relatedlink",
              "model": "relatedlink",
              "classes_targetpathone": "ctaTarget-sameTab",
              "classes_targetpathtwo": "ctaTarget-sameTab-two",
              "classes_exitinterstitialtwo": "ctaExitInterstitial-select-two",
              "classes_exitinterstitial": "ctaExitInterstitial-select"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "relatedlink",
      "fields": [
        {
          "component": "container",
          "name": "cta_oneButton",
          "valueType": "string",
          "fields": [
            {
              "component": "select",
              "name": "classes_ctatypeone",
              "label": "CTA Selection for Link Headline",
              "description": "ⓘ Select the CTA Selection Link/Asset(PDF/Image)",
              "options": [
                {
                  "name": "Link",
                  "value": "ctaSelection-link"
                },
                {
                  "name": "Asset (PDF/Image)",
                  "value": "ctaSelection-asset"
                }
              ]
            },
            {
              "component": "text",
              "name": "linkText",
              "label": "Link Headline",
              "valueType": "string",
              "description": "Enter display text for the quick link",
              "required": true,
              "condition": {
                "===": [
                  {
                    "var": "cta_oneButton|classes_ctatypeone"
                  },
                  "ctaSelection-link"
                ]
              }
            },
            {
              "component": "text",
              "name": "assetlinkText",
              "label": "Link Headlinet Asset",
              "valueType": "string",
              "description": "Enter display text for the quick link for Asset(PDF/Image)",
              "required": true,
              "condition": {
                "===": [
                  {
                    "var": "cta_oneButton|classes_ctatypeone"
                  },
                  "ctaSelection-asset"
                ]
              }
            },
            {
              "component": "aem-content",
              "name": "link",
              "label": "CTA Link",
              "valueType": "string",
              "description": "Enter the URL to navigate when CTA is clicked",
              "required": true,
              "validation": {
                "rootPath": "/content"
              },
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "cta_oneButton|classes_ctatypeone"
                      },
                      "ctaSelection-link"
                    ]
                  },
                  {
                    "!!": {
                      "var": "cta_oneButton|linkText"
                    }
                  }
                ]
              }
            },
            {
              "component": "custom-asset-namespace:custom-asset",
              "configUrl": "/content/dam/custom-asset-picker/image.config.json",
              "name": "assetlink",
              "label": "Asset (PDF/Image)",
              "description": "Upload the Asset (PDF/Image)",
              "valueType": "string",
              "required": true,
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "cta_oneButton|classes_ctatypeone"
                      },
                      "ctaSelection-asset"
                    ]
                  },
                  {
                    "!!": {
                      "var": "cta_oneButton|assetlinkText"
                    }
                  }
                ]
              }
            },
            {
              "component": "text",
              "name": "linkTitle",
              "label": "ARIA Label Link Headline",
              "valueType": "string",
              "description": "Enter ARIA label to comply ADA",
              "condition": {
                "===": [
                  {
                    "var": "cta_oneButton|classes_ctatypeone"
                  },
                  "ctaSelection-link"
                ]
              }
            },
            {
              "component": "text",
              "name": "assetlinkTitle",
              "label": "ARIA Label Link Headline Asset",
              "valueType": "string",
              "description": "Enter ARIA label to comply ADA",
              "condition": {
                "===": [
                  {
                    "var": "cta_oneButton|classes_ctatypeone"
                  },
                  "ctaSelection-asset"
                ]
              }
            },
            {
              "component": "select",
              "name": "classes_targetpathone",
              "label": "Target Path",
              "description": "Select the target path for the authored CTA URL",
              "value": "ctaTarget-sameTab",
              "options": [
                {
                  "name": "Same Tab",
                  "value": "ctaTarget-sameTab"
                },
                {
                  "name": "New Tab",
                  "value": "ctaTarget-newTab"
                }
              ],
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "cta_oneButton|classes_ctatypeone"
                      },
                      "ctaSelection-link"
                    ]
                  },
                  {
                    "!!": {
                      "var": "cta_oneButton|linkText"
                    }
                  }
                ]
              }
            },
            {
              "component": "select",
              "label": "Exit Interstitial",
              "name": "classes_exitinterstitial",
              "valueType": "string",
              "value": "ctaExitInterstitial-select",
              "description": "Select this option to enable the modal experience that notifies user that they are leaving the site",
              "options": [
                {
                  "name": "select",
                  "value": "ctaExitInterstitial-select"
                },
                {
                  "name": "General Third Parties",
                  "value": "ctaExitInterstitial-general-third-parties"
                },
                {
                  "name": "Telehealth",
                  "value": "ctaExitInterstitial-telehealth"
                },
                {
                  "name": "Account",
                  "value": "ctaExitInterstitial-account"
                },
                {
                  "name": "Account Wellbeing",
                  "value": "ctaExitInterstitial-account-wellbeing"
                },
                {
                  "name": "Embedded Tools Healthgrades",
                  "value": "ctaExitInterstitial-embedded-tools-healthgrades"
                },
                {
                  "name": "Embedded Tools Nourish",
                  "value": "ctaExitInterstitial-embedded-tools-nourish"
                }
              ],
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "cta_oneButton|classes_ctatypeone"
                      },
                      "ctaSelection-link"
                    ]
                  },
                  {
                    "!!": {
                      "var": "cta_oneButton|linkText"
                    }
                  }
                ]
              }
            },
            {
              "component": "text",
              "valueType": "string",
              "name": "relatedlinks_description",
              "label": "Description",
              "description": "Enter the description"
            }
          ]
        },

        {
          "component": "container",
          "name": "cta_twoButton",
          "valueType": "string",
          "fields": [
            {
              "component": "select",
              "name": "classes_ctatypetwo",
              "label": "CTA Selection for sub headline",
              "description": "ⓘ Select the CTA Selection Link/Asset(PDF/Image)",
              "options": [
                {
                  "name": "Link",
                  "value": "ctaSelection-link-two"
                },
                {
                  "name": "Asset (PDF/Image)",
                  "value": "ctaSelection-asset-two"
                }
              ]
            },
            {
              "component": "text",
              "name": "seclinkText",
              "label": "Sub-text Headline",
              "valueType": "string",
              "description": "Enter display text for the  quick link sub-text",
              "condition": {
                "===": [
                  {
                    "var": "cta_twoButton|classes_ctatypetwo"
                  },
                  "ctaSelection-link-two"
                ]
              }
            },
            {
              "component": "text",
              "name": "secassetlinkText",
              "label": "Sub-text Headline Asset",
              "valueType": "string",
              "description": "Enter display text for the  quick link sub-text  Asset(PDF/Image)",
              "condition": {
                "===": [
                  {
                    "var": "cta_twoButton|classes_ctatypetwo"
                  },
                  "ctaSelection-asset-two"
                ]
              }
            },
            {
              "component": "aem-content",
              "name": "seclink",
              "label": "Sub-text CTA Link",
              "valueType": "string",
              "description": "Enter the URL to navigate when CTA is clicked",
              "required": true,
              "validation": {
                "rootPath": "/content"
              },
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "cta_twoButton|classes_ctatypetwo"
                      },
                      "ctaSelection-link-two"
                    ]
                  },
                  {
                    "!!": {
                      "var": "cta_twoButton|seclinkText"
                    }
                  }
                ]
              }
            },
            {
              "component": "custom-asset-namespace:custom-asset",
              "configUrl": "/content/dam/custom-asset-picker/image.config.json",
              "name": "secassetlink",
              "label": "Sub-text CTA Asset (PDF/Image)",
              "description": "Upload the Asset (PDF/Image)",
              "required": true,
              "valueType": "string",
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "cta_twoButton|classes_ctatypetwo"
                      },
                      "ctaSelection-asset-two"
                    ]
                  },
                  {
                    "!!": {
                      "var": "cta_twoButton|secassetlinkText"
                    }
                  }
                ]
              }
            },
            {
              "component": "text",
              "name": "seclinkTitle",
              "label": "ARIA Label for Sub-text Headline",
              "valueType": "string",
              "description": "Enter ARIA label to comply ADA",
              "condition": {
                "===": [
                  {
                    "var": "cta_twoButton|classes_ctatypetwo"
                  },
                  "ctaSelection-link-two"
                ]
              }
            },
            {
              "component": "text",
              "name": "secassetlinkTitle",
              "label": "ARIA Label for Sub-text Headline Asset",
              "valueType": "string",
              "description": "Enter ARIA label to comply ADA",
              "condition": {
                "===": [
                  {
                    "var": "cta_twoButton|classes_ctatypetwo"
                  },
                  "ctaSelection-asset-two"
                ]
              }
            },
            {
              "component": "select",
              "name": "classes_targetpathtwo",
              "label": "Target Path",
              "description": "Select the target path for the authored CTA URL",
              "value": "ctaTarget-sameTab-two",
              "options": [
                {
                  "name": "Same Tab",
                  "value": "ctaTarget-sameTab-two"
                },
                {
                  "name": "New Tab",
                  "value": "ctaTarget-newTab-two"
                }
              ],
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "cta_twoButton|classes_ctatypetwo"
                      },
                      "ctaSelection-link-two"
                    ]
                  },
                  {
                    "!!": {
                      "var": "cta_twoButton|seclinkText"
                    }
                  }
                ]
              }
            },
            {
              "component": "select",
              "label": "Exit Interstitial",
              "name": "classes_exitinterstitialtwo",
              "valueType": "string",
              "value": "ctaExitInterstitial-select-two",
              "description": "Select this option to enable the modal experience that notifies user that they are leaving the site",
              "options": [
                {
                  "name": "select",
                  "value": "ctaExitInterstitial-select-two"
                },
                {
                  "name": "General Third Parties",
                  "value": "ctaExitInterstitial-general-third-parties-two"
                },
                {
                  "name": "Telehealth",
                  "value": "ctaExitInterstitial-telehealth-two"
                },
                {
                  "name": "Account",
                  "value": "ctaExitInterstitial-account-two"
                },
                {
                  "name": "Account Wellbeing",
                  "value": "ctaExitInterstitial-account-wellbeing-two"
                },
                {
                  "name": "Embedded Tools Healthgrades",
                  "value": "ctaExitInterstitial-embedded-tools-healthgrades-two"
                },
                {
                  "name": "Embedded Tools Nourish",
                  "value": "ctaExitInterstitial-embedded-tools-nourish-two"
                }
              ],
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "cta_twoButton|classes_ctatypetwo"
                      },
                      "ctaSelection-link-two"
                    ]
                  },
                  {
                    "!!": {
                      "var": "cta_twoButton|seclinkText"
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
