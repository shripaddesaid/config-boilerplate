{
  "definitions": [
    {
      "title": "External Video Player Link Item",
      "id": "external-video-player-link-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "model": "external-video-player-link-item",
              "name": "External Video Player Link Item",
              "classes_ctacolorone": "ctaColor-light",
              "classes_ctastyleone": "ctaStyle-primary",
              "classes_exitinterstitial": "ctaExitInterstitial-select"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "external-video-player-link-item",
      "fields": [
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "label": "Desktop Image Thumbnail",
          "name": "videoPlayer_image",
          "description": "Upload Desktop Image Thumbnail",
          "required": true
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "videoPlayer_imageMimeType"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "videoPlayer_imageAlt",
          "label": "Alt Text for Desktop Image Thumbnail",
          "description": "Pick alt text from AEM DAM with ability to override it",
          "required": true,
          "default": "Alt text from AEM DAM",
          "condition": {
            "!!": {
              "var": "videoPlayer_image"
            }
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "label": "Mobile Image Thumbnail",
          "name": "mobileImage",
          "description": "Upload  Mobile Image Thumbnail"
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "mobileImageMimeType"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "mobileImageAlt",
          "label": "Mobile Image Alt text Thumbnail",
          "description": "Pick alt text for background Mobile Image Thumbnail from AEM DAM with ability to override it",
          "required": true,
          "default": "Alt text from AEM DAM",
          "condition": {
            "!!": {
              "var": "mobileImage"
            }
          }
        },
        {
          "component": "richtext",
          "valueType": "string",
          "name": "title",
          "label": "Title",
          "description": "Enter the title of the tile"
        },
        {
          "component": "select",
          "name": "classes_titleRtefontsize",
          "label": "Title Font Size",
          "description": "Select the font size for the Card Title",
          "options": [
            { "name": "100px", "value": "title-fs-100px" },
            { "name": "60px", "value": "title-fs-60px" },
            { "name": "48px", "value": "title-fs-48px" },
            { "name": "36px", "value": "title-fs-36px" },
            { "name": "32px", "value": "title-fs-32px" },
            { "name": "28px", "value": "title-fs-28px" },
            { "name": "24px", "value": "title-fs-24px" },
            { "name": "20px", "value": "title-fs-20px" },
            { "name": "16px", "value": "title-fs-16px" },
            { "name": "14px", "value": "title-fs-14px" }
          ]
        },
        {
          "component": "select",
          "name": "classes_ctacolorone",
          "label": "CTA Color",
          "description": "Select the color for CTA Button Primary implies Green: #79DE00 Secondary implies White: #FFFFFF",
          "value": "ctaColor-light",
          "options": [
            {
              "name": "Light",
              "value": "ctaColor-light"
            },
            {
              "name": "Dark",
              "value": "ctaColor-dark"
            }
          ]
        },
        {
          "component": "select",
          "name": "classes_ctastyleone",
          "label": "CTA Style",
          "description": "Select the style of the Button CTA",
          "value": "ctaStyle-primary",
          "options": [
            {
              "name": "Primary",
              "value": "ctaStyle-primary"
            },
            {
              "name": "Secondary",
              "value": "ctaStyle-secondary"
            },
            {
              "name": "Neutral",
              "value": "ctaStyle-neutral"
            }
          ]
        },
        {
          "component": "select",
          "name": "classes_ctatypeone",
          "label": "CTA Selection",
          "description": "ⓘ Select the CTA Selection Link/Asset(PDF/Image)",
          "options": [
            {
              "name": "Link",
              "value": "ctaSelection-link"
            },
            {
              "name": "Asset (PDF/Image)",
              "value": "ctaSelection-asset"
            }
          ]
        },
        {
          "component": "text",
          "name": "linkText",
          "label": "CTA Text",
          "valueType": "string",
          "description": "Enter label to display on the CTA",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "classes_ctatypeone"
              },
              "ctaSelection-link"
            ]
          }
        },
        {
          "component": "text",
          "name": "assetlinkText",
          "label": "CTA Text Asset",
          "valueType": "string",
          "description": "Enter label to display on the CTA for Asset(PDF/Image)",
          "condition": {
            "===": [
              {
                "var": "classes_ctatypeone"
              },
              "ctaSelection-asset"
            ]
          }
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "CTA Link",
          "valueType": "string",
          "description": "Enter the URL to navigate when CTA is clicked",
          "required": true,
          "validation": {
            "rootPath": "/content"
          },
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "classes_ctatypeone"
                  },
                  "ctaSelection-link"
                ]
              },
              {
                "!!": {
                  "var": "linkText"
                }
              }
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "name": "assetlink",
          "label": "Asset (PDF/Image)",
          "description": "Upload the Asset (PDF/Image)",
          "valueType": "string",
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "classes_ctatypeone"
                  },
                  "ctaSelection-asset"
                ]
              },
              {
                "!!": {
                  "var": "assetlinkText"
                }
              }
            ]
          }
        },
        {
          "component": "text",
          "name": "linkTitle",
          "label": "ARIA Label for CTA link",
          "valueType": "string",
          "description": "Enter ARIA label to comply ADA",
          "condition": {
            "===": [
              {
                "var": "classes_ctatypeone"
              },
              "ctaSelection-link"
            ]
          }
        },
        {
          "component": "text",
          "name": "assetlinkTitle",
          "label": "ARIA Label for CTA Asset",
          "valueType": "string",
          "description": "Enter ARIA label to comply ADA",
          "condition": {
            "===": [
              {
                "var": "classes_ctatypeone"
              },
              "ctaSelection-asset"
            ]
          }
        },
        {
          "component": "select",
          "label": "Exit Interstitial",
          "name": "classes_exitinterstitial",
          "valueType": "string",
          "value": "ctaExitInterstitial-select",
          "description": "Select this option to enable the modal experience that notifies user that they are leaving the site",
          "options": [
            {
              "name": "Select",
              "value": "ctaExitInterstitial-select"
            },
            {
              "name": "General Third Parties",
              "value": "ctaExitInterstitial-general-third-parties"
            },
            {
              "name": "Telehealth",
              "value": "ctaExitInterstitial-telehealth"
            },
            {
              "name": "Account",
              "value": "ctaExitInterstitial-account"
            },
            {
              "name": "Account Wellbeing",
              "value": "ctaExitInterstitial-account-wellbeing"
            },
            {
              "name": "Embedded Tools Healthgrades",
              "value": "ctaExitInterstitial-embedded-tools-healthgrades"
            },
            {
              "name": "Embedded Tools Nourish",
              "value": "ctaExitInterstitial-embedded-tools-nourish"
            }
          ],
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "classes_ctatypeone"
                  },
                  "ctaSelection-link"
                ]
              },
              {
                "!!": {
                  "var": "linkText"
                }
              }
            ]
          }
        }
      ]
    },
    {
      "id": "external-video-player-link",
      "fields": []
    }
  ]
}
