{
  "definitions": [
    {
      "title": "Pull Quote",
      "id": "pull-quote",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Pull Quote",
              "model": "pull-quote",
              "classes_componenttype": "image-none",
              "classes_imageposition": "align-left",
              "classes_alignment": "icon-align-left"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "pull-quote",
      "fields": [
        {
          "component": "select",
          "name": "classes_componenttype",
          "label": "Component Type",
          "description": "Select layout of quote block",
          "value": "image-none",
          "options": [
            {
              "name": "No Image",
              "value": "image-none"
            },
            {
              "name": "With Image",
              "value": "image-quote-block"
            }
          ]
        },
        {
          "component": "container",
          "name": "imagecontainer",
          "label": "With image Field Details",
          "valueType": "string",
          "condition": {
            "===": [
              {
                "var": "classes_componenttype"
              },
              "image-quote-block"
            ]
          },
          "fields": [
            {
              "component": "select",
              "name": "classes_imageposition",
              "label": "Image Position",
              "description": "Select the appropriate column for image placement",
              "value": "align-left",
              "valueType": "string",
              "required": true,
              "options": [
                {
                  "name": "Left",
                  "value": "align-left"
                },
                {
                  "name": "Right",
                  "value": "align-right"
                }
              ]
            },
            {
              "component": "custom-asset-namespace:custom-asset",
              "configUrl": "/content/dam/custom-asset-picker/image.config.json",
              "valueType": "string",
              "name": "image",
              "label": "Image",
              "required": true,
              "description": "Upload image for the component"
            },
            {
              "component": "custom-asset-namespace:custom-asset-mimetype",
              "valueType": "string",
              "name": "imageMimeType"
            },
            {
              "component": "text",
              "name": "imageAlt",
              "label": "Image Alt text",
              "description": "Pick alt text from AEM DAM with ability to override it",
              "required": true
            }
          ]
        },
        {
          "component": "select",
          "name": "classes_alignment",
          "label": "Alignment",
          "description": "Select alignment of of icon placed on top",
          "condition": {
            "===": [
              {
                "var": "classes_componenttype"
              },
              "image-none"
            ]
          },
          "value": "icon-align-left",
          "options": [
            {
              "name": "Left",
              "value": "icon-align-left"
            },
            {
              "name": "Center",
              "value": "icon-align-center"
            }
          ]
        },
        {
          "component": "richtext",
          "name": "quote",
          "label": "Quote",
          "valueType": "string",
          "description": "Enter title for each card",
          "required": true
        },
        {
          "component": "select",
          "name": "classes_quotertefontsize",
          "label": "Quote Font Size",
          "description": "Select the font size for the quote",
          "value": "quote-fs-36px",
          "options": [
            {
              "name": "100px",
              "value": "quote-fs-100px"
            },
            {
              "name": "60px",
              "value": "quote-fs-60px"
            },
            {
              "name": "48px",
              "value": "quote-fs-48px"
            },
            {
              "name": "36px",
              "value": "quote-fs-36px"
            },
            {
              "name": "32px",
              "value": "quote-fs-32px"
            },
            {
              "name": "28px",
              "value": "quote-fs-28px"
            },
            {
              "name": "24px",
              "value": "quote-fs-24px"
            },
            {
              "name": "20px",
              "value": "quote-fs-20px"
            },
            {
              "name": "16px",
              "value": "quote-fs-16px"
            },
            {
              "name": "14px",
              "value": "quote-fs-14px"
            }
          ]
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "pullquote_authortext",
          "label": "Author",
          "description": "Enter description for each card"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "pullquote_authortitle",
          "label": "Author Title",
          "description": "Enter Author Title"
        }
      ]
    }
  ]
}
