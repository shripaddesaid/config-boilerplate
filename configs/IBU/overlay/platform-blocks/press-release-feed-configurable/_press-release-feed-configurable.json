{
  "definitions": [
    {
      "title": "Press Release Feed [Configurable]",
      "id": "press-release-feed-configurable",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Press Release Feed Configurable",
              "model": "press-release-feed-configurable",
              "classes_componentTypeClasses": "entire-feed",
              "classes_customFeed": "three-press-releases"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "press-release-feed-configurable",
      "fields": [
        {
          "component": "aem-tag",
          "label": "Category",
          "name": "pressReleaseFeedConfigurableTags",
          "valueType": "string",
          "description": "Select the tags for which feed needs to be displayed.",
          "rootPath": "/content/cq:tags"
        },
        {
          "component": "select",
          "label": "Component Type",
          "name": "classes_componentTypeClasses",
          "valueType": "string",
          "description": "Select the desired type",
          "required": true,
          "options": [
            {
              "name": "Entire Feed",
              "value": "entire-feed"
            },
            {
              "name": "Custom Feed",
              "value": "custom-feed"
            }
          ]
        },
        {
          "component": "select",
          "label": "Number of Press Releases results",
          "name": "classes_customFeed",
          "valueType": "string",
          "description": "Select the number of press releases to be displayed in the feed.",
          "options": [
            { "name": "3", "value": "three-press-releases" },
            { "name": "4", "value": "four-press-releases" },
            { "name": "5", "value": "five-press-releases" },
            { "name": "6", "value": "six-press-releases" },
            { "name": "7", "value": "seven-press-releases" },
            { "name": "8", "value": "eight-press-releases" },
            { "name": "9", "value": "nine-press-releases" }
          ],
          "condition": {
            "===": [{ "var": "classes_componentTypeClasses" }, "custom-feed"]
          }
        }
      ]
    }
  ]
}
