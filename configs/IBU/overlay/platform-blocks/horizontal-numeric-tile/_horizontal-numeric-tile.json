{
  "definitions": [
    {
      "title": "Horizontal Numeric Tile",
      "id": "horizontal-numeric-tile",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Horizontal Numeric Tile",
              "model": "horizontal-numeric-tile",
              "filter": "horizontal-numeric-tile",
              "classes_horizontalTileType": "variation-1",
              "item0": {
                "sling:resourceType": "core/franklin/components/block/v1/block/item",
                "name": "Numeric Tile",
                "model": "numeric-tile"
              }
            }
          }
        }
      }
    }
  ],
  "filters": [
    {
      "id": "horizontal-numeric-tile",
      "components": ["numeric-tile"]
    }
  ],
  "models": [
    {
      "id": "horizontal-numeric-tile",
      "fields": [
        {
          "component": "select",
          "name": "classes_horizontalTileType",
          "label": "Variations",
          "description": "Select between Variation 1 and Variation 2",
          "value": "variation-1",
          "valueType": "string",
          "required": true,
          "options": [
            {
              "name": "Variation 1",
              "value": "variation-1"
            },
            {
              "name": "Variation 2",
              "value": "variation-2"
            },
            {
              "name": "Variation 3",
              "value": "variation-3"
            }
          ]
        },
        {
          "component": "richtext",
          "name": "title",
          "label": "Section Title",
          "valueType": "string",
          "description": "Enter the title for the section."
        },
        {
          "component": "select",
          "name": "classes_sectionTitleRteFontSize",
          "label": "Title Font Size",
          "description": "Select the font size for the description",
          "options": [
            { "name": "100px", "value": "sectionTitle-fs-100px" },
            { "name": "60px", "value": "sectionTitle-fs-60px" },
            { "name": "48px", "value": "sectionTitle-fs-48px" },
            { "name": "36px", "value": "sectionTitle-fs-36px" },
            { "name": "32px", "value": "sectionTitle-fs-32px" },
            { "name": "28px", "value": "sectionTitle-fs-28px" },
            { "name": "24px", "value": "sectionTitle-fs-24px" },
            { "name": "20px", "value": "sectionTitle-fs-20px" },
            { "name": "16px", "value": "sectionTitle-fs-16px" },
            { "name": "14px", "value": "sectionTitle-fs-14px" }
          ]
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Section Description",
          "valueType": "string",
          "description": "Enter the description for the section",
          "required": true
        },
        {
          "component": "select",
          "name": "classes_sectionDescriptionRteFontSize",
          "label": "Section Description Font Size",
          "description": "Select the font size for the description",
          "options": [
            { "name": "100px", "value": "sectionDescription-fs-100px" },
            { "name": "60px", "value": "sectionDescription-fs-60px" },
            { "name": "48px", "value": "sectionDescription-fs-48px" },
            { "name": "36px", "value": "sectionDescription-fs-36px" },
            { "name": "32px", "value": "sectionDescription-fs-32px" },
            { "name": "28px", "value": "sectionDescription-fs-28px" },
            { "name": "24px", "value": "sectionDescription-fs-24px" },
            { "name": "20px", "value": "sectionDescription-fs-20px" },
            { "name": "16px", "value": "sectionDescription-fs-16px" },
            { "name": "14px", "value": "sectionDescription-fs-14px" }
          ]
        },
        {
          "component": "richtext",
          "name": "footer",
          "label": "Footer",
          "valueType": "string",
          "description": "Enter the footer",
          "condition": {
            "===": [
              {
                "var": "classes_horizontalTileType"
              },
              "variation-2"
            ]
          }
        },
        {
          "component": "select",
          "name": "classes_footerRteFontSize",
          "label": "Footer Font Size",
          "description": "Select the font size for the description",
          "condition": {
            "===": [
              {
                "var": "classes_horizontalTileType"
              },
              "variation-2"
            ]
          },
          "options": [
            { "name": "100px", "value": "footerDescription-fs-100px" },
            { "name": "60px", "value": "footerDescription-fs-60px" },
            { "name": "48px", "value": "footerDescription-fs-48px" },
            { "name": "36px", "value": "footerDescription-fs-36px" },
            { "name": "32px", "value": "footerDescription-fs-32px" },
            { "name": "28px", "value": "footerDescription-fs-28px" },
            { "name": "24px", "value": "footerDescription-fs-24px" },
            { "name": "20px", "value": "footerDescription-fs-20px" },
            { "name": "16px", "value": "footerDescription-fs-16px" },
            { "name": "14px", "value": "footerDescription-fs-14px" }
          ]
        }
      ]
    }
  ]
}
