{
  "definitions": [
    {
      "title": "Telehealth Card",
      "id": "telehealth-card",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Telehealth Card",
              "model": "telehealth-card",
              "classes_targetpathone": "ctaTarget-sameTab",
              "classes_exitinterstitial": "ctaExitInterstitial-select"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "telehealth-card",
      "fields": [
        {
          "component": "select",
          "name": "classes_backgroundcolor",
          "label": "Background Color",
          "description": "Select the background color",
          "required": true,
          "options": [
            {
              "name": "Primary Green",
              "value": "backgroundColor-#F0F8F6"
            },
            {
              "name": "Primary Red",
              "value": "backgroundColor-#FBF5F4"
            },
            {
              "name": "Tertiary Blue",
              "value": "backgroundColor-#F3F7FA"
            },
            {
              "name": "None",
              "value": "backgroundColor-none"
            }
          ]
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "name": "image",
          "label": "Image",
          "description": "Upload images for the card",
          "required": true
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "imageMimeType"
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "Image Alt text",
          "valueType": "string",
          "description": "Pick alt text from AEM DAM with ability to override it",
          "required": true,
          "value": "Alt text from AEM DAM"
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Description",
          "valueType": "string",
          "description": "Enter description for each card"
        },
        {
          "...": "../utils/eds-commons/_rte-description.json#/rte-description"
        },
        {
          "...": "../utils/eds-commons/_single-ctafields.json#/cta-one"
        }
      ]
    }
  ]
}
