{
  "definitions": [
    {
      "title": "Bulleted Icon List Item",
      "id": "bulleted-icon-list-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Bulleted Icon List Item",
              "model": "bulleted-icon-list-item"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "bulleted-icon-list-item",
      "fields": [
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "name": "image",
          "label": "Icon",
          "required": true,
          "description": "Select or upload an icon for the tile."
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "imageMimeType"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Icon Alt Text ",
          "description": "Pick alt text from AEM DAM with ability to override it",
          "required": true
        },
        {
          "component": "richtext",
          "name": "icondescription",
          "label": "Icon Description",
          "valueType": "string",
          "description": "Enter the description"
        },
        {
          "component": "select",
          "name": "classes_icondescriptionRteFontSize",
          "label": "Icon Description Font Size",
          "description": "Select the font size for the icon description",
          "options": [
            { "name": "100px", "value": "icondescription-fs-100px" },
            { "name": "60px", "value": "icondescription-fs-60px" },
            { "name": "48px", "value": "icondescription-fs-48px" },
            { "name": "36px", "value": "icondescription-fs-36px" },
            { "name": "32px", "value": "icondescription-fs-32px" },
            { "name": "28px", "value": "icondescription-fs-28px" },
            { "name": "24px", "value": "icondescription-fs-24px" },
            { "name": "20px", "value": "icondescription-fs-20px" },
            { "name": "16px", "value": "icondescription-fs-16px" },
            { "name": "14px", "value": "icondescription-fs-14px" }
          ]
        }
      ]
    }
  ]
}
