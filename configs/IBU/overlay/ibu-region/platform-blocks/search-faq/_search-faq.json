{
  "definitions": [
    {
      "title": "Search FAQ",
      "id": "search-faq",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Search FAQ",
              "model": "search-faq",
              "filter": "search-faq",
              "searchfaq_subtitleType": "h1",
              "searchfaq_titleType": "h6",
              "item0": {
                "sling:resourceType": "core/franklin/components/block/v1/block/item",
                "name": "Search FAQ Item",
                "model": "search-faq-item"
              }
            }
          }
        }
      }
    }
  ],
  "filters": [
    {
      "id": "search-faq",
      "components": ["search-faq-item"]
    }
  ],
  "models": [
