{
  "definitions": [
    {
      "title": "News Tile Item",
      "id": "news-tile-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "News Tile Item",
              "model": "news-tile-item",
              "classes_targetpathone": "ctaTarget-sameTab",
              "classes_exitinterstitial": "ctaExitInterstitial-select",
              "date-time": "2025-05-27T00:00:00.000Z"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "news-tile-item",
      "fields": [
        {
          "component": "richtext",
          "name": "eyebrowText",
          "label": "Eyebrow",
          "valueType": "string",
          "description": "Enter the Eyebrow text"
        },
        {
          "component": "richtext",
          "name": "news_newsTileTitle",
          "label": "Title",
          "valueType": "string",
          "description": "Enter the Title",
          "required": true
        },
        {
          "...": "../utils/eds-commons/_rte-title.json#/rte-title"
        },
        {
          "component": "date-time",
          "label": "Date",
          "name": "news_date",
          "valueType": "date",
          "description": "Select the date",
          "value": "2025-05-27T00:00:00.000Z",
          "required": true
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "newsTileDescription",
          "valueType": "string",
          "description": "Enter the description"
        },
        {
          "...": "../utils/eds-commons/_rte-description.json#/rte-description"
        },
        {
          "component": "select",
          "name": "classes_ctatypeone",
          "label": "CTA Selection",
          "description": "ⓘ Select the CTA Selection Link/Asset(PDF/Image)",
          "options": [
            {
              "name": "Link",
              "value": "ctaSelection-link"
            },
            {
              "name": "Asset (PDF/Image)",
              "value": "ctaSelection-asset"
            }
          ]
        },
        {
          "component": "text",
          "name": "linkText",
          "label": "CTA Text",
          "valueType": "string",
          "description": "Enter label to display on the CTA",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "classes_ctatypeone"
              },
              "ctaSelection-link"
            ]
          }
        },
        {
          "component": "text",
          "name": "assetlinkText",
          "label": "CTA Text Asset",
          "valueType": "string",
          "description": "Enter label to display on the CTA for Asset(PDF/Image)",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "classes_ctatypeone"
              },
              "ctaSelection-asset"
            ]
          }
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "CTA Link",
          "valueType": "string",
          "description": "Enter the URL to navigate when CTA is clicked",
          "validation": {
            "rootPath": "/content"
          },
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "classes_ctatypeone"
                  },
                  "ctaSelection-link"
                ]
              },
              {
                "!!": {
                  "var": "linkText"
                }
              }
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "name": "assetlink",
          "label": "Asset (PDF/Image)",
          "description": "Upload the Asset (PDF/Image)",
          "valueType": "string",
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "classes_ctatypeone"
                  },
                  "ctaSelection-asset"
                ]
              },
              {
                "!!": {
                  "var": "assetlinkText"
                }
              }
            ]
          }
        },
        {
          "component": "text",
          "name": "linkTitle",
          "label": "ARIA Label for CTA link",
          "valueType": "string",
          "description": "Enter ARIA label to comply ADA",
          "condition": {
            "===": [
              {
                "var": "classes_ctatypeone"
              },
              "ctaSelection-link"
            ]
          }
        },
        {
          "component": "text",
          "name": "assetlinkTitle",
          "label": "ARIA Label for CTA Asset",
          "valueType": "string",
          "description": "Enter ARIA label to comply ADA",
          "condition": {
            "===": [
              {
                "var": "classes_ctatypeone"
              },
              "ctaSelection-asset"
            ]
          }
        },
        {
          "component": "select",
          "name": "classes_targetpathone",
          "label": "Target Path",
          "description": "Select the target path for the authored CTA URL",
          "value": "ctaTarget-sameTab",
          "options": [
            {
              "name": "Same Tab",
              "value": "ctaTarget-sameTab"
            },
            {
              "name": "New Tab",
              "value": "ctaTarget-newTab"
            }
          ],
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "classes_ctatypeone"
                  },
                  "ctaSelection-link"
                ]
              },
              {
                "!!": {
                  "var": "linkText"
                }
              }
            ]
          }
        },
        {
          "component": "select",
          "label": "Exit Interstitial",
          "name": "classes_exitinterstitial",
          "valueType": "string",
          "value": "ctaExitInterstitial-select",
          "description": "Select this option to enable the modal experience that notifies user that they are leaving the site",
          "options": [
            {
              "name": "select",
              "value": "ctaExitInterstitial-select"
            },
            {
              "name": "General Third Parties",
              "value": "ctaExitInterstitial-general-third-parties"
            },
            {
              "name": "Telehealth",
              "value": "ctaExitInterstitial-telehealth"
            },
            {
              "name": "Account",
              "value": "ctaExitInterstitial-account"
            },
            {
              "name": "Account Wellbeing",
              "value": "ctaExitInterstitial-account-wellbeing"
            },
            {
              "name": "Embedded Tools Healthgrades",
              "value": "ctaExitInterstitial-embedded-tools-healthgrades"
            },
            {
              "name": "Embedded Tools Nourish",
              "value": "ctaExitInterstitial-embedded-tools-nourish"
            }
          ],
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "classes_ctatypeone"
                  },
                  "ctaSelection-link"
                ]
              },
              {
                "!!": {
                  "var": "linkText"
                }
              }
            ]
          }
        }
      ]
    }
  ]
}
