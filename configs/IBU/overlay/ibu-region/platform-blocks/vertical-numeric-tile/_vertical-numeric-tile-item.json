{
  "definitions": [
    {
      "title": "Vertical Numeric Tile Item",
      "id": "vertical-numeric-tile-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Vertical Numeric Tile Item",
              "model": "vertical-numeric-tile-item",
              "classes_textposition": "position-left"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "vertical-numeric-tile-item",
      "fields": [
        {
          "component": "text",
          "name": "verticlenumerictileitem_redtext",
          "label": "Red Text",
          "description": "Enter the value to be displayed on the tile.",
          "required": true,
          "valueType": "string",
          "validation": {
            "minLength": 1,
            "maxLength": 4,
            "customErrorMsg": "Maximum characters length limit should not be more than 4"
          }
        },
        {
          "component": "select",
          "name": "classes_textposition",
          "label": "Position",
          "description": "Choose the text alignment within the Promo Banner component",
          "value": "position-left",
          "required": true,
          "options": [
            {
              "name": "Left",
              "value": "position-left"
            },
            {
              "name": "Top",
              "value": "position-top"
            }
          ]
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Description",
          "description": "Enter the description"
        },
        {
          "...": "../utils/eds-commons/_rte-description.json#/rte-description"
        }
      ]
    }
  ]
}
