{
  "definitions": [
    {
      "title": "Hero",
      "id": "hero",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Hero",
              "model": "hero",
              "filter": "hero"
            }
          }
        }
      }
    }
  ],
  "filters": [
    {
      "id": "hero",
      "components": ["icongrid-tile"]
    }
  ],
  "models": [
    {
      "id": "hero",
      "fields": [
        {
          "component": "select",
          "name": "PrimarybackgroundType",
          "label": "Primary Background Type",
          "description": "Select Background Type Primary Hero",
          "required": true,
          "options": [
            {
              "name": "Image",
              "value": "imageSlide"
            },
            {
              "name": "Video",
              "value": "videoSlide"
            }
          ]
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/imageconfig.json",
          "valueType": "string",
          "name": "BackgroundImage",
          "label": "Background Image",
          "description": "Upload Image for the Primary Hero",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "PrimarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "BackgroundImageMimeType",
          "condition": {
            "===": [
              {
                "var": "PrimarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "Image Alt",
          "label": "Image Alt Text",
          "description": "Add Alt Text for Image Primary Hero",
          "condition": {
            "===": [
              {
                "var": "PrimarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "label": "Background Video",
          "name": "BackgroundVideo",
          "description": "Upload video for the Primary Hero",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "PrimarybackgroundType"
              },
              "videoSlide"
            ]
          }
        },
        {
          "component": "boolean",
          "label": "Enable Overlay?",
          "name": "EnableOverlay",
          "valueType": "boolean",
          "description": "Enable Overlay video for the Primary Hero"
        },
        {
          "component": "text-input",
          "valueType": "string",
          "name": "overlayTitle",
          "label": "Overlay Title",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "EnableOverlay"
              },
              true
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/imageconfig.json",
          "valueType": "string",
          "name": "icon",
          "label": "Icon",
          "description": "Upload the icon image",
          "condition": {
            "===": [
              {
                "var": "PrimarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "iconMimeType",
          "condition": {
            "===": [
              {
                "var": "PrimarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "Icon Alt text",
          "valueType": "string",
          "description": "Pick alt text from AEM DAM with ability to override it",
          "condition": {
            "===": [
              {
                "var": "PrimarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "select",
          "name": "textcolor",
          "label": "Text Color",
          "description": "Select the Text Color",
          "value": "white",
          "required": true,
          "options": [
            {
              "name": "Black",
              "value": "black"
            },
            {
              "name": "White",
              "value": "white"
            }
          ],
          "condition": {
            "===": [
              {
                "var": "PrimarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "text",
          "name": "ctaLabel",
          "label": "First CTA Label",
          "valueType": "string",
          "description": "Enter label to display on the CTA for each card",
          "condition": {
            "===": [
              {
                "var": "PrimarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "select",
          "name": "ctaStyle",
          "label": "CTA Style",
          "description": "Select the style of the Button CTA",
          "value": "primary",
          "options": [
            {
              "name": "Primary",
              "value": "primary"
            },
            {
              "name": "Secondary",
              "value": "secondary"
            }
          ],
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "ctaLabel" } }
            ]
          }
        },
        {
          "component": "select",
          "name": "ctaType",
          "label": "CTA Selection",
          "description": "Select the CTA Type",
          "options": [
            {
              "name": "Link",
              "value": "link"
            },
            {
              "name": "Asset (PDF/Image)",
              "value": "asset"
            }
          ],
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "ctaLabel" } }
            ]
          }
        },
        {
          "component": "aem-content",
          "name": "ctaLink",
          "label": "CTA Link",
          "valueType": "string",
          "description": "Enter the URL to navigate when CTA is clicked for each card",
          "validation": {
            "rootPath": "/content"
          },
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "ctaLabel" } },
              { "===": [{ "var": "ctaType" }, "link"] }
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/imageconfig.json",
          "name": "ctaAsset",
          "label": "Asset (PDF/Image)",
          "description": "Upload the Asset (PDF/Image)",
          "valueType": "string",
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "ctaLabel" } },
              { "===": [{ "var": "ctaType" }, "asset"] }
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "ctaAssetMimeType",
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "ctaLabel" } },
              { "===": [{ "var": "ctaType" }, "asset"] }
            ]
          }
        },
        {
          "component": "text",
          "name": "width-media-aria-label",
          "label": "ARIA Label",
          "valueType": "string",
          "description": "Enter ARIA label to comply ADA",
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] }
            ]
          }
        },
        {
          "component": "select",
          "name": "targetPath",
          "label": "Target Path",
          "description": "Select the target path for the authored CTA URL",
          "value": "sameTab",
          "options": [
            {
              "name": "Same Tab",
              "value": "sameTab"
            },
            {
              "name": "New Tab",
              "value": "newTab"
            }
          ],
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "ctaLabel" } },
              { "===": [{ "var": "ctaType" }, "link"] }
            ]
          }
        },
        {
          "component": "checkbox-group",
          "label": "Exit Interstitial",
          "name": "exitInterstitial",
          "valueType": "string",
          "options": [
            {
              "name": "Exit Interstitial",
              "value": "true"
            }
          ],
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "ctaLabel" } },
              { "===": [{ "var": "ctaType" }, "link"] }
            ]
          }
        },
        {
          "component": "text",
          "name": "secCtaLabel",
          "label": "Second CTA Label",
          "valueType": "string",
          "description": "Enter label to display on the CTA for each card",
          "condition": {
            "===": [
              {
                "var": "PrimarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "select",
          "name": "secCtaStyle",
          "label": "CTA Style",
          "description": "Select the style of the Button CTA",
          "value": "primary",
          "options": [
            {
              "name": "Primary",
              "value": "primary"
            },
            {
              "name": "Secondary",
              "value": "secondary"
            }
          ],
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "secCtaLabel" } }
            ]
          }
        },
        {
          "component": "select",
          "name": "secCtaType",
          "label": "CTA Selection",
          "description": "Select the CTA Type",
          "options": [
            {
              "name": "Link",
              "value": "link"
            },
            {
              "name": "Asset (PDF/Image)",
              "value": "asset"
            }
          ],
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "secCtaLabel" } }
            ]
          }
        },
        {
          "component": "aem-content",
          "name": "secCtaLink",
          "label": "CTA Link",
          "valueType": "string",
          "description": "Enter the URL to navigate when CTA is clicked for each card",
          "validation": {
            "rootPath": "/content"
          },
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "secCtaLabel" } },
              { "===": [{ "var": "secCtaType" }, "link"] }
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/imageconfig.json",
          "name": "secCtaAsset",
          "label": "Asset (PDF/Image)",
          "description": "Upload the Asset (PDF/Image)",
          "valueType": "string",
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "secCtaLabel" } },
              { "===": [{ "var": "secCtaType" }, "asset"] }
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "secCtaAssetMimeType",
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "secCtaLabel" } },
              { "===": [{ "var": "secCtaType" }, "asset"] }
            ]
          }
        },
        {
          "component": "text",
          "name": "sec-width-media-aria-label",
          "label": "ARIA Label",
          "valueType": "string",
          "description": "Enter ARIA label to comply ADA",
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] }
            ]
          }
        },
        {
          "component": "select",
          "name": "secTargetPath",
          "label": "Target Path",
          "description": "Select the target path for the authored CTA URL",
          "value": "sameTab",
          "options": [
            {
              "name": "Same Tab",
              "value": "sameTab"
            },
            {
              "name": "New Tab",
              "value": "newTab"
            }
          ],
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "secCtaLabel" } },
              { "===": [{ "var": "secCtaType" }, "link"] }
            ]
          }
        },
        {
          "component": "checkbox-group",
          "label": "Exit Interstitial",
          "name": "secExitInterstitial",
          "valueType": "string",
          "options": [
            {
              "name": "Exit Interstitial",
              "value": "true"
            }
          ],
          "condition": {
            "and": [
              { "===": [{ "var": "PrimarybackgroundType" }, "imageSlide"] },
              { "!!": { "var": "secCtaLabel" } },
              { "===": [{ "var": "secCtaType" }, "link"] }
            ]
          }
        },
        {
          "component": "text",
          "name": "text",
          "label": "Title",
          "valueType": "string",
          "description": "Enter main heading for the Primary Hero",
          "validation": {
            "minLength": 0,
            "maxLength": 70,
            "regExp": "^foo:.*",
            "customErrorMsg": "Maximum Characters length limit should not be more than 70"
          }
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Description",
          "valueType": "string",
          "description": "Enter description for additional context"
        }
      ]
    }
  ]
}
