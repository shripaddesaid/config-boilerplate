{
  "definitions": [
    {
      "title": "Primary Hero",
      "id": "primary-hero",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Primary Hero",
              "model": "primary-hero",
              "filter": "primary-hero",
              "classes_titleFont": "titlefont-Ringside",
              "classes_size": "herosize-large",
              "classes_textcolor": "textcolor-white",
              "classes_overlayEffect": "overlay-light",
              "classes_ctaNumber": "ctaNumber-one",
              "classes_ctacolorone": "ctaColor-light",
              "classes_ctastyleone": "ctaStyle-primary",
              "classes_targetpathone": "ctaTarget-sameTab",
              "classes_exitinterstitial": "ctaExitInterstitial-select",
              "classes_ctacolortwo": "ctaColor-light-two",
              "classes_ctastyletwo": "ctaStyle-primary-two",
              "classes_targetpathtwo": "ctaTarget-sameTab_two",
              "classes_exitinterstitialtwo": "ctaExitInterstitial-select_two"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "primary-hero",
      "fields": [
        {
          "component": "select",
          "name": "classes_primarybackgroundType",
          "label": "Primary Background Type",
          "description": "Select background image/video for the Primary Hero",
          "required": true,
          "options": [
            {
              "name": "Image",
              "value": "imageSlide"
            },
            {
              "name": "Video",
              "value": "videoSlide"
            }
          ]
        },
        {
          "component": "richtext",
          "name": "text",
          "label": "Title",
          "valueType": "string",
          "description": "Enter main heading for the Primary Hero"
        },
        {
          "component": "select",
          "name": "classes_textRteFontSize",
          "label": "Title Font Size",
          "description": "Select the font size for the title",
          "options": [
            { "name": "100px", "value": "title-fs-100px" },
            { "name": "60px", "value": "title-fs-60px" },
            { "name": "48px", "value": "title-fs-48px" },
            { "name": "36px", "value": "title-fs-36px" },
            { "name": "32px", "value": "title-fs-32px" },
            { "name": "28px", "value": "title-fs-28px" },
            { "name": "24px", "value": "title-fs-24px" },
            { "name": "20px", "value": "title-fs-20px" },
            { "name": "16px", "value": "title-fs-16px" },
            { "name": "14px", "value": "title-fs-14px" }
          ]
        },
        {
          "component": "select",
          "name": "classes_titleFont",
          "label": "Title Font",
          "valueType": "string",
          "value": "titlefont-Ringside",
          "description": "Select a font for the title",
          "options": [
            {
              "name": "Garamond",
              "value": "titlefont-Garamond"
            },
            {
              "name": "Ringside",
              "value": "titlefont-Ringside"
            }
          ]
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Description",
          "valueType": "string",
          "description": "Enter description for additional context"
        },
        {
          "component": "select",
          "name": "classes_descriptionRteFontSize",
          "label": "Description Font Size",
          "description": "Select the font size for the description",
          "options": [
            { "name": "100px", "value": "description-fs-100px" },
            { "name": "60px", "value": "description-fs-60px" },
            { "name": "48px", "value": "description-fs-48px" },
            { "name": "36px", "value": "description-fs-36px" },
            { "name": "32px", "value": "description-fs-32px" },
            { "name": "28px", "value": "description-fs-28px" },
            { "name": "24px", "value": "description-fs-24px" },
            { "name": "20px", "value": "description-fs-20px" },
            { "name": "16px", "value": "description-fs-16px" },
            { "name": "14px", "value": "description-fs-14px" }
          ]
        },
        {
          "component": "select",
          "name": "classes_size",
          "label": "Size",
          "value": "herosize-large",
          "description": "Enter the size of the hero",
          "options": [
            {
              "name": "Medium",
              "value": "herosize-medium"
            },
            {
              "name": "Large",
              "value": "herosize-large"
            }
          ],
          "condition": {
            "===": [
              {
                "var": "classes_primarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "boolean",
          "label": "Offset Content?",
          "name": "OffsetContent",
          "valueType": "boolean",
          "description": "Offset content on the left in the hero section"
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "name": "image",
          "label": "Background Image",
          "description": "Upload Image for the Primary Hero",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "classes_primarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "imageMimeType"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Image Alt Text",
          "description": "Pick alt text for background image from AEM DAM with ability to override it",
          "condition": {
            "===": [
              {
                "var": "classes_primarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "name": "videoPath",
          "label": "Video Path",
          "description": "Upload the full-length video",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "classes_primarybackgroundType"
              },
              "videoSlide"
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "videoPathMimeType"
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "name": "icon",
          "label": "Icon",
          "description": "Upload the icon image",
          "condition": {
            "===": [
              {
                "var": "classes_primarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "iconMimeType"
        },
        {
          "component": "text",
          "name": "iconAlt",
          "label": "Icon Alt text",
          "valueType": "string",
          "description": "Pick alt text from AEM DAM with ability to override it",
          "condition": {
            "===": [
              {
                "var": "classes_primarybackgroundType"
              },
              "imageSlide"
            ]
          }
        },
        {
          "component": "select",
          "name": "classes_textcolor",
          "label": "Text Color",
          "description": "Select the Text Color",
          "value": "textcolor-white",
          "required": true,
          "options": [
            {
              "name": "Black",
              "value": "textcolor-black"
            },
            {
              "name": "White",
              "value": "textcolor-white"
            }
          ],
          "condition": {
            "or": [
              {
                "===": [
                  { "var": "classes_primarybackgroundType" },
                  "imageSlide"
                ]
              },
              {
                "===": [
                  { "var": "classes_primarybackgroundType" },
                  "videoSlide"
                ]
              }
            ]
          }
        },
        {
          "component": "checkbox-group",
          "name": "enableGradient",
          "valueType": "boolean",
          "label": "Enable Gradient",
          "description": "Select this checkbox to enable gradient on Background image",
          "condition": {
            "===": [
              {
                "var": "classes_primarybackgroundType"
              },
              "imageSlide"
            ]
          },
          "options": [
            {
              "name": "Enable Gradient",
              "value": "true"
            }
          ]
        },
        {
          "component": "select",
          "name": "classes_overlayEffect",
          "label": "Overlay Effect",
          "description": "Select overlay effect on the Background image",
          "value": "overlay-light",
          "condition": {
            "and": [
              {
                "in": [
                  "true",
                  {
                    "var": "enableGradient"
                  }
                ]
              },
              {
                "===": [
                  {
                    "var": "classes_primarybackgroundType"
                  },
                  "imageSlide"
                ]
              }
            ]
          },
          "options": [
            {
              "name": "Light",
              "value": "overlay-light"
            },
            {
              "name": "Medium",
              "value": "overlay-medium"
            },
            {
              "name": "Dark",
              "value": "overlay-dark"
            }
          ]
        },
        {
          "component": "select",
          "name": "classes_ctaNumber",
          "label": "Number of CTA(s)",
          "description": "Select the number of CTA(s) required",
          "value": "ctaNumber-one",
          "condition": {
            "===": [
              {
                "var": "classes_primarybackgroundType"
              },
              "imageSlide"
            ]
          },
          "options": [
            {
              "name": "One",
              "value": "ctaNumber-one"
            },
            {
              "name": "Two",
              "value": "ctaNumber-two"
            }
          ]
        },
        {
          "component": "container",
          "collapsible": true,
          "name": "primary_oneButton",
          "label": "First Button CTA Fields",
          "valueType": "string",
          "condition": {
            "===": [
              {
                "var": "classes_primarybackgroundType"
              },
              "imageSlide"
            ]
          },
          "fields": [
            {
              "component": "select",
              "name": "classes_ctacolorone",
              "label": "CTA Color",
              "description": "Select the color for CTA Button Primary implies Green: #79DE00 Secondary implies White: #FFFFFF",
              "value": "ctaColor-light",
              "options": [
                {
                  "name": "Light",
                  "value": "ctaColor-light"
                },
                {
                  "name": "Dark",
                  "value": "ctaColor-dark"
                }
              ]
            },
            {
              "component": "select",
              "name": "classes_ctastyleone",
              "label": "CTA Style",
              "description": "Select the style of the Button CTA",
              "value": "ctaStyle-primary",
              "options": [
                {
                  "name": "Primary",
                  "value": "ctaStyle-primary"
                },
                {
                  "name": "Secondary",
                  "value": "ctaStyle-secondary"
                },
                { "name": "Neutral", "value": "ctaStyle-neutral" }
              ]
            },
            {
              "component": "select",
              "name": "classes_ctatypeone",
              "label": "CTA Selection",
              "description": "ⓘ Select the CTA selection",
              "options": [
                {
                  "name": "Link",
                  "value": "ctaSelection-link"
                },
                {
                  "name": "Asset (PDF/Image)",
                  "value": "ctaSelection-asset"
                }
              ]
            },
            {
              "component": "text",
              "name": "linkText",
              "label": "CTA Label",
              "valueType": "string",
              "description": "Enter the label to display on each card",
              "condition": {
                "===": [
                  {
                    "var": "primary_oneButton|classes_ctatypeone"
                  },
                  "ctaSelection-link"
                ]
              }
            },
            {
              "component": "text",
              "name": "assetlinkText",
              "label": "CTA Label for Asset",
              "valueType": "string",
              "description": "Enter label to display on the CTA for Asset(PDF/Image)",
              "condition": {
                "===": [
                  {
                    "var": "primary_oneButton|classes_ctatypeone"
                  },
                  "ctaSelection-asset"
                ]
              }
            },
            {
              "component": "aem-content",
              "name": "link",
              "label": "CTA Link",
              "valueType": "string",
              "description": "Enter the URL to navigate when CTA is clicked for each card",
              "validation": {
                "rootPath": "/content"
              },
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "primary_oneButton|classes_ctatypeone"
                      },
                      "ctaSelection-link"
                    ]
                  },
                  {
                    "!!": {
                      "var": "primary_oneButton|linkText"
                    }
                  }
                ]
              }
            },
            {
              "component": "custom-asset-namespace:custom-asset",
              "configUrl": "/content/dam/custom-asset-picker/image.config.json",
              "name": "assetlink",
              "label": "Asset (PDF/Image)",
              "description": "Upload the Asset (PDF/Image)",
              "valueType": "string",
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "primary_oneButton|classes_ctatypeone"
                      },
                      "ctaSelection-asset"
                    ]
                  },
                  {
                    "!!": {
                      "var": "primary_oneButton|assetlinkText"
                    }
                  }
                ]
              }
            },
            {
              "component": "text",
              "name": "linkTitle",
              "label": "CTA Aria Label",
              "valueType": "string",
              "description": "Enter ARIA label to comply ADA",
              "condition": {
                "===": [
                  {
                    "var": "primary_oneButton|classes_ctatypeone"
                  },
                  "ctaSelection-link"
                ]
              }
            },
            {
              "component": "text",
              "name": "assetlinkTitle",
              "label": "CTA ARIA Label for Asset",
              "valueType": "string",
              "description": "Enter ARIA label to comply ADA",
              "condition": {
                "===": [
                  {
                    "var": "primary_oneButton|classes_ctatypeone"
                  },
                  "ctaSelection-asset"
                ]
              }
            },
            {
              "component": "select",
              "name": "classes_targetpathone",
              "label": "Target Path",
              "description": "Select the target path for the authored CTA URL",
              "value": "ctaTarget-sameTab",
              "options": [
                {
                  "name": "Same Tab",
                  "value": "ctaTarget-sameTab"
                },
                {
                  "name": "New Tab",
                  "value": "ctaTarget-newTab"
                }
              ],
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "primary_oneButton|classes_ctatypeone"
                      },
                      "ctaSelection-link"
                    ]
                  },
                  {
                    "!!": {
                      "var": "primary_oneButton|linkText"
                    }
                  }
                ]
              }
            },
            {
              "component": "select",
              "label": "Exit Interstitial",
              "name": "classes_exitinterstitial",
              "valueType": "string",
              "value": "ctaExitInterstitial-select",
              "description": "Select this option to enable the modal experience that notifies the user that they are leaving the site",
              "options": [
                {
                  "name": "Select",
                  "value": "ctaExitInterstitial-select"
                },
                {
                  "name": "General Third Parties",
                  "value": "ctaExitInterstitial-general-third-parties"
                },
                {
                  "name": "Telehealth",
                  "value": "ctaExitInterstitial-telehealth"
                },
                {
                  "name": "Account",
                  "value": "ctaExitInterstitial-account"
                },
                {
                  "name": "Account Wellbeing",
                  "value": "ctaExitInterstitial-account-wellbeing"
                },
                {
                  "name": "Embedded Tools Healthgrades",
                  "value": "ctaExitInterstitial-embedded-tools-healthgrades"
                },
                {
                  "name": "Embedded Tools Nourish",
                  "value": "ctaExitInterstitial-embedded-tools-nourish"
                }
              ],
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "primary_oneButton|classes_ctatypeone"
                      },
                      "ctaSelection-link"
                    ]
                  },
                  {
                    "!!": {
                      "var": "primary_oneButton|linkText"
                    }
                  }
                ]
              }
            }
          ]
        },
        {
          "component": "container",
          "collapsible": true,
          "name": "primary_twoButton",
          "label": "Second Button CTA Fields",
          "valueType": "string",
          "condition": {
            "and": [
              {
                "===": [
                  {
                    "var": "classes_primarybackgroundType"
                  },
                  "imageSlide"
                ]
              },
              {
                "===": [
                  {
                    "var": "classes_ctaNumber"
                  },
                  "ctaNumber-two"
                ]
              }
            ]
          },
          "fields": [
            {
              "component": "select",
              "name": "classes_ctacolortwo",
              "label": "CTA Color",
              "description": "Select the color for CTA Button Primary implies Green: #79DE00 Secondary implies White: #FFFFFF",
              "value": "ctaColor-light-two",
              "options": [
                {
                  "name": "Light",
                  "value": "ctaColor-light-two"
                },
                {
                  "name": "Dark",
                  "value": "ctaColor-dark-two"
                }
              ]
            },
            {
              "component": "select",
              "name": "classes_ctastyletwo",
              "label": "CTA Style",
              "description": "Select the style of the Button CTA",
              "value": "ctaStyle-primary-light-two",
              "options": [
                {
                  "name": "Primary",
                  "value": "ctaStyle-primary-two"
                },
                {
                  "name": "Secondary",
                  "value": "ctaStyle-secondary-two"
                },
                {
                  "name": "Neutral",
                  "value": "ctaStyle-neutral-two"
                }
              ]
            },
            {
              "component": "select",
              "name": "classes_ctatypetwo",
              "label": "CTA Selection",
              "description": "ⓘ Select the CTA Selection Link/Asset(PDF/Image)",
              "options": [
                {
                  "name": "Link",
                  "value": "ctaSelection-link_two"
                },
                {
                  "name": "Asset (PDF/Image)",
                  "value": "ctaSelection-asset_two"
                }
              ]
            },
            {
              "component": "text",
              "name": "link1Text",
              "label": "CTA Label for link",
              "valueType": "string",
              "description": "Enter label to display on the CTA",
              "condition": {
                "===": [
                  {
                    "var": "primary_twoButton|classes_ctatypetwo"
                  },
                  "ctaSelection-link_two"
                ]
              }
            },
            {
              "component": "aem-content",
              "name": "link1",
              "label": "CTA Link",
              "valueType": "string",
              "description": "Enter the URL to navigate when CTA is clicked",
              "validation": {
                "rootPath": "/content"
              },
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "primary_twoButton|classes_ctatypetwo"
                      },
                      "ctaSelection-link_two"
                    ]
                  },
                  {
                    "!!": {
                      "var": "primary_twoButton|link1Text"
                    }
                  }
                ]
              }
            },
            {
              "component": "text",
              "name": "assetlink1Text",
              "label": "CTA Label for Asset",
              "valueType": "string",
              "description": "Enter label to display on the CTA for Asset(PDF/Image)",
              "condition": {
                "===": [
                  {
                    "var": "primary_twoButton|classes_ctatypetwo"
                  },
                  "ctaSelection-asset_two"
                ]
              }
            },
            {
              "component": "custom-asset-namespace:custom-asset",
              "configUrl": "/content/dam/custom-asset-picker/image.config.json",
              "name": "assetlink1",
              "label": "Asset (PDF/Image)",
              "description": "Upload the Asset (PDF/Image)",
              "valueType": "string",
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "primary_twoButton|classes_ctatypetwo"
                      },
                      "ctaSelection-asset_two"
                    ]
                  },
                  {
                    "!!": {
                      "var": "primary_twoButton|assetlink1Text"
                    }
                  }
                ]
              }
            },
            {
              "component": "text",
              "name": "link1Title",
              "label": "CTA ARIA Label for link",
              "valueType": "string",
              "description": "Enter ARIA label to comply ADA",
              "condition": {
                "===": [
                  {
                    "var": "primary_twoButton|classes_ctatypetwo"
                  },
                  "ctaSelection-link_two"
                ]
              }
            },
            {
              "component": "text",
              "name": "assetlink1Title",
              "label": "CTA ARIA Label for Asset",
              "valueType": "string",
              "description": "Enter ARIA label to comply ADA",
              "condition": {
                "===": [
                  {
                    "var": "primary_twoButton|classes_ctatypetwo"
                  },
                  "ctaSelection-asset_two"
                ]
              }
            },
            {
              "component": "select",
              "name": "classes_targetpathtwo",
              "label": "Target Path",
              "description": "Select the target path for the authored CTA URL",
              "value": "ctaTarget-sameTab_two",
              "options": [
                {
                  "name": "Same Tab",
                  "value": "ctaTarget-sameTab_two"
                },
                {
                  "name": "New Tab",
                  "value": "ctaTarget-newTab_two"
                }
              ],
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "primary_twoButton|classes_ctatypetwo"
                      },
                      "ctaSelection-link_two"
                    ]
                  },
                  {
                    "!!": {
                      "var": "primary_twoButton|link1Text"
                    }
                  }
                ]
              }
            },
            {
              "component": "select",
              "label": "Exit Interstitial",
              "name": "classes_exitinterstitialtwo",
              "valueType": "string",
              "value": "ctaExitInterstitial-select_two",
              "description": "Select this option to enable the modal experience that notifies user that they are leaving the site",
              "options": [
                {
                  "name": "Select",
                  "value": "ctaExitInterstitial-select_two"
                },
                {
                  "name": "General Third Parties",
                  "value": "ctaExitInterstitial-general-third-parties_two"
                },
                {
                  "name": "Telehealth",
                  "value": "ctaExitInterstitial-telehealth_two"
                },
                {
                  "name": "Account",
                  "value": "ctaExitInterstitial-account_two"
                },
                {
                  "name": "Account Wellbeing",
                  "value": "ctaExitInterstitial-account-wellbeing_two"
                },
                {
                  "name": "Embedded Tools Healthgrades",
                  "value": "ctaExitInterstitial-embedded-tools-healthgrades_two"
                },
                {
                  "name": "Embedded Tools Nourish",
                  "value": "ctaExitInterstitial-embedded-tools-nourish_two"
                }
              ],
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "primary_twoButton|classes_ctatypetwo"
                      },
                      "ctaSelection-link_two"
                    ]
                  },
                  {
                    "!!": {
                      "var": "primary_twoButton|link1Text"
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
