{
  "definitions": [
    {
      "title": "Price Card",
      "id": "price-card",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Price Card",
              "model": "price-card",
              "filter": "price-card",
              "classes_cardcolor": "cardcolor-primary",
              "classes": "ctaNumber-one",
              "classes_ctacolorone": "ctaColor-light",
              "classes_ctastyleone": "ctaStyle-primary",
              "classes_targetpathone": "ctaTarget-sameTab",
              "classes_exitinterstitial": "ctaExitInterstitial-select",
              "classes_targetpathtwo": "ctaTarget-sameTab_two",
              "classes_ctacolortwo": "ctaColor-light-two",
              "classes_ctastyletwo": "ctaStyle-primary-two",
              "classes_exitinterstitialtwo": "ctaExitInterstitial-select_two",
              "item0": {
                "sling:resourceType": "core/franklin/components/block/v1/block/item",
                "name": "Green Card",
                "model": "green-card",
                "classes_cardcolor": "cardcolor-primary",
                "classes_highlightcolor": "highlight-deep-secondary"
              }
            }
          }
        }
      }
    }
  ],
  "filters": [
    {
      "id": "price-card",
      "components": ["green-card"]
    }
  ],
  "models": [
    {
      "id": "price-card",
      "fields": [
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "name": "pricecard_image",
          "label": "Image",
          "required": true,
          "description": "Upload thumbnail image"
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "pricecard_imageMimeType"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "pricecard_imageAlt",
          "label": "Image Alt text",
          "description": "Enter alternative text for the background. Can override AEM DAM alt text.",
          "required": true
        },
        {
          "component": "richtext",
          "name": "eyebrow",
          "label": "Eyebrow",
          "valueType": "string",
          "description": "Enter the eyebrow text"
        },
        {
          "component": "select",
          "name": "classes_eyebrowRtefontsize",
          "label": "Eyebrow Font Size",
          "description": "Select the font size for the Eyebrow",
          "options": [
            { "name": "100px", "value": "eyebrow-fs-100px" },
            { "name": "60px", "value": "eyebrow-fs-60px" },
            { "name": "48px", "value": "eyebrow-fs-48px" },
            { "name": "36px", "value": "eyebrow-fs-36px" },
            { "name": "32px", "value": "eyebrow-fs-32px" },
            { "name": "28px", "value": "eyebrow-fs-28px" },
            { "name": "24px", "value": "eyebrow-fs-24px" },
            { "name": "20px", "value": "eyebrow-fs-20px" },
            { "name": "16px", "value": "eyebrow-fs-16px" },
            { "name": "14px", "value": "eyebrow-fs-14px" }
          ]
        },
        {
          "component": "richtext",
          "name": "pricecard_title",
          "label": "Title",
          "valueType": "string",
          "description": "Enter the Price card title",
          "required": true
        },
        {
          "component": "select",
          "name": "classes_titleRtefontsize",
          "label": "Title Font Size",
          "description": "Select the font size for the Card Title",
          "options": [
            { "name": "100px", "value": "title-fs-100px" },
            { "name": "60px", "value": "title-fs-60px" },
            { "name": "48px", "value": "title-fs-48px" },
            { "name": "36px", "value": "title-fs-36px" },
            { "name": "32px", "value": "title-fs-32px" },
            { "name": "28px", "value": "title-fs-28px" },
            { "name": "24px", "value": "title-fs-24px" },
            { "name": "20px", "value": "title-fs-20px" },
            { "name": "16px", "value": "title-fs-16px" },
            { "name": "14px", "value": "title-fs-14px" }
          ]
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Description",
          "valueType": "string",
          "description": "Enter the description for Price card"
        },
        {
          "component": "select",
          "name": "classes_descriptionRtefontsize",
          "label": "Description Font Size",
          "description": "Select the font size for the Description",
          "options": [
            { "name": "100px", "value": "description-fs-100px" },
            { "name": "60px", "value": "description-fs-60px" },
            { "name": "48px", "value": "description-fs-48px" },
            { "name": "36px", "value": "description-fs-36px" },
            { "name": "32px", "value": "description-fs-32px" },
            { "name": "28px", "value": "description-fs-28px" },
            { "name": "24px", "value": "description-fs-24px" },
            { "name": "20px", "value": "description-fs-20px" },
            { "name": "16px", "value": "description-fs-16px" },
            { "name": "14px", "value": "description-fs-14px" }
          ]
        },
        {
          "component": "richtext",
          "name": "cardDescription",
          "label": "Card Description",
          "valueType": "string",
          "description": "Enter the description to be displayed below the green card"
        },
        {
          "component": "select",
          "name": "classes_cardDescriptionRtefontsize",
          "label": "Card Description Font Size",
          "description": "Select the font size for the Card Description",
          "options": [
            { "name": "100px", "value": "carddescription-fs-100px" },
            { "name": "60px", "value": "carddescription-fs-60px" },
            { "name": "48px", "value": "carddescription-fs-48px" },
            { "name": "36px", "value": "carddescription-fs-36px" },
            { "name": "32px", "value": "carddescription-fs-32px" },
            { "name": "28px", "value": "carddescription-fs-28px" },
            { "name": "24px", "value": "carddescription-fs-24px" },
            { "name": "20px", "value": "carddescription-fs-20px" },
            { "name": "16px", "value": "carddescription-fs-16px" },
            { "name": "14px", "value": "carddescription-fs-14px" }
          ]
        },
        {
          "component": "select",
          "name": "classes",
          "label": "Number of CTA(s)",
          "description": "Select the number of CTA(s) required",
          "value": "ctaNumber-one",
          "options": [
            {
              "name": "One",
              "value": "ctaNumber-one"
            },
            {
              "name": "Two",
              "value": "ctaNumber-two"
            }
          ]
        },
        {
          "component": "container",
          "collapsible": true,
          "name": "card_oneButton",
          "label": "First Button CTA Fields",
          "valueType": "string",
          "fields": [
            {
              "component": "select",
              "name": "classes_ctacolorone",
              "label": "CTA Color",
              "description": "Select the color for CTA Button Primary implies Green: #79DE00 Secondary implies White: #FFFFFF",
              "value": "ctaColor-light",
              "options": [
                {
                  "name": "Light",
                  "value": "ctaColor-light"
                },
                {
                  "name": "Dark",
                  "value": "ctaColor-dark"
                }
              ]
            },
            {
              "component": "select",
              "name": "classes_ctastyleone",
              "label": "CTA Style",
              "description": "Select the style of the Button CTA",
              "value": "ctaStyle-primary",
              "options": [
                {
                  "name": "Primary",
                  "value": "ctaStyle-primary"
                },
                {
                  "name": "Secondary",
                  "value": "ctaStyle-secondary"
                },
                { "name": "Neutral", "value": "ctaStyle-neutral" }
              ]
            },
            {
              "component": "select",
              "name": "classes_ctatypeone",
              "label": "CTA Selection",
              "description": "ⓘ Select the CTA selection",
              "options": [
                {
                  "name": "Link",
                  "value": "ctaSelection-link"
                },
                {
                  "name": "Asset (PDF/Image)",
                  "value": "ctaSelection-asset"
                }
              ]
            },
            {
              "component": "text",
              "name": "linkText",
              "label": "CTA label",
              "valueType": "string",
              "description": "Enter the label to display on each card",
              "condition": {
                "===": [
                  {
                    "var": "card_oneButton|classes_ctatypeone"
                  },
                  "ctaSelection-link"
                ]
              }
            },
            {
              "component": "text",
              "name": "assetlinkText",
              "label": "CTA Label for Asset",
              "valueType": "string",
              "description": "Enter label to display on the CTA for Asset(PDF/Image)",
              "condition": {
                "===": [
                  {
                    "var": "card_oneButton|classes_ctatypeone"
                  },
                  "ctaSelection-asset"
                ]
              }
            },

            {
              "component": "aem-content",
              "name": "link",
              "label": "CTA Link",
              "valueType": "string",
              "description": "Enter the URL to navigate when CTA is clicked for each card",
              "validation": {
                "rootPath": "/content"
              },
              "condition": {
                "and": [
                  {
                    "===": [
                      {
                        "var": "card_oneButton|classes_ctatypeone"
                      },
                      "ctaSelection-link"
                    ]
                  },
                  {
                    "!!": {
                      "var": "card_oneButton|linkText"
                    }
                  }
                ]
              }
            },
            {
              "component": "custom-asset-namespace:custom-asset",
