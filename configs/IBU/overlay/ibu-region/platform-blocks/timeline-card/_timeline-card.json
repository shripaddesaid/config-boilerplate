{
  "definitions": [
    {
      "title": "Timeline Card",
      "id": "timeline-card",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Timeline Card",
              "model": "timeline-card",
              "classes_imageplacement": "imagePlacement-left"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "timeline-card",
      "fields": [
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "name": "image",
          "label": "Image",
          "required": true,
          "description": "Upload background image for the Media Banner"
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "imageMimeType"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Image Alt Text ",
          "description": "Pick alt text from AEM DAM with ability to override it",
          "required": true
        },
        {
          "component": "select",
          "name": "classes_imageplacement",
          "label": "Image Placement",
          "description": "Choose where the image should be placed",
          "required": true,
          "value": "imagePlacement-left",
          "options": [
            {
              "name": "Top",
              "value": "imagePlacement-top"
            },
            {
              "name": "Left",
              "value": "imagePlacement-left"
            },
            {
              "name": "Right",
              "value": "imagePlacement-right"
            }
          ]
        },
        {
          "component": "richtext",
          "name": "title",
          "label": "Title",
          "valueType": "string",
          "description": "Enter the title",
          "required": true
        },
        {
          "...": "../utils/eds-commons/_rte-title.json#/rte-title"
        },
        {
          "component": "richtext",
          "name": "description",
          "label": "Description",
          "valueType": "string",
          "description": "Enter the description"
        },
        {
          "...": "../utils/eds-commons/_rte-description.json#/rte-description"
        }
      ]
    }
  ]
}
