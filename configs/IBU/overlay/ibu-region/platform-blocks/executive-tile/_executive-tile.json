{
  "definitions": [
    {
      "title": "Executive Tile",
      "id": "executive-tile",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Executive Tile",
              "model": "executive-tile",
              "classes_targetpathone": "ctaTarget-sameTab",
              "classes_exitinterstitial": "ctaExitInterstitial-select"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "executive-tile",
      "fields": [
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "name": "image",
          "label": "Image",
          "required": true,
          "description": "Upload Image"
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "imageMimeType"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "exImageAlt",
          "label": "Image Alt text",
          "description": "Pick alt text from AEM DAM with ability to override it",
          "required": true,
          "value": "Alt text from AEM DAM"
        },
        {
          "component": "richtext",
          "valueType": "string",
          "label": "Name",
          "name": "executiveName",
          "description": "Enter the Executive’s name",
          "required": true
        },
        {
          "...": "../utils/eds-commons/_rte-description.json#/rte-description"
        },
        {
          "component": "text",
          "valueType": "string",
          "label": "Designation",
          "name": "executiveTile_executiveDesignation",
          "description": "Enter the Executive’s Designation",
          "required": true
        },
        {
          "component": "checkbox-group",
          "label": "Instagram Profile",
          "name": "instagramProfile",
          "valueType": "boolean",
          "description": "Select if the Executive’s Instagram profile is available",
          "options": [
            {
              "name": "InstagramProfile",
              "value": "true"
            }
          ]
        },
        {
          "component": "aem-content",
          "name": "executiveTile_instagramURL",
          "label": "Instagram URL",
          "description": "Enter the Instagram profile URL",
          "required": true,
          "valueType": "string",
          "condition": {
            "in": [
              "true",
              {
                "var": "instagramProfile"
              }
            ]
          }
        },
        {
          "component": "checkbox-group",
          "label": "X Profile",
          "name": "xProfile",
          "valueType": "boolean",
          "description": "Select if the Executive’s X profile is available",
          "options": [
            {
              "name": "XProfile",
              "value": "true"
            }
          ]
        },
        {
          "component": "aem-content",
          "name": "executiveTile_xURL",
          "description": "Enter the X profile URL",
          "label": "X URL",
          "valueType": "string",
          "required": true,
          "condition": {
            "in": [
              "true",
              {
                "var": "xProfile"
              }
            ]
          },
          "validation": {
            "rootPath": "/content"
          }
        },
        {
          "component": "checkbox-group",
          "label": "LinkedIn Profile",
          "name": "linkedInProfile",
          "valueType": "boolean",
          "description": "Select if the Executive’s LinkedIn profile is available",
          "options": [
            {
              "name": "linkedInProfile",
              "value": "true"
            }
          ]
        },
        {
          "component": "aem-content",
          "name": "executiveTile_linkedInURL",
          "label": "LinkedIn URL",
          "description": "Enter the LinkedIn profile URL",
          "required": true,
          "valueType": "string",
          "condition": {
            "in": [
              "true",
              {
                "var": "linkedInProfile"
              }
            ]
          }
        },
        {
          "...": "../utils/eds-commons/_single-ctafields.json#/cta-one"
        }
      ]
    }
  ]
}
