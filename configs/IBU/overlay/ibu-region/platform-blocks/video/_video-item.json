{
  "definitions": [
    {
      "title": "Video Item",
      "id": "video-item",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/item",
            "template": {
              "name": "Video Item",
              "model": "video-item",
              "classes": "video-standard",
              "classes_titleplacement": "titleplacement-top",
              "classes_descriptionplacement": "descriptionplacement-center",
              "classes_ctacolor": "ctaColor-light",
              "classes_ctastyle": "ctaStyle-primary",
              "classes_buttonctastyle": "buttonctastyle-arrow",
              "video_videoPathStandardText": "Watch now",
              "video_videoPathQuoteText": "Watch patient story"
            }
          }
        }
      }
    }
  ],
  "filters": [],
  "models": [
    {
      "id": "video-item",
      "fields": [
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "name": "video_image",
          "label": "Image Thumbnail",
          "description": "Upload the image thumbnail",
          "required": true
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "video_imageMimeType"
        },
        {
          "component": "text",
          "name": "video_imageAlt",
          "valueType": "string",
          "label": "Image Alt Text",
          "description": "Pick alt text from AEM DAM with ability to override it",
          "required": true
        },
        {
          "component": "select",
          "name": "classes",
          "label": "Video Type",
          "description": "Select the appropriate variation",
          "value": "video-standard",
          "options": [
            {
              "name": "Video [Standard]",
              "value": "video-standard"
            },
            {
              "name": "Video with Quote",
              "value": "video-quote"
            }
          ]
        },
        {
          "component": "container",
          "name": "videoStandardContainer",
          "label": "Video [Standard] Fields",
          "valueType": "string",
          "condition": {
            "===": [
              {
                "var": "classes"
              },
              "video-standard"
            ]
          },
          "fields": [
            {
              "component": "select",
              "name": "classes_titleplacement",
              "label": "Title Placement",
              "description": "Select the appropriate position for Title placement on the left side of the viewport.",
              "value": "titleplacement-top",
              "required": true,
              "options": [
                {
                  "name": "Top",
                  "value": "titleplacement-top"
                },
                {
                  "name": "Bottom",
                  "value": "titleplacement-bottom"
                },
                {
                  "name": "Center",
                  "value": "titleplacement-center"
                }
              ]
            },
            {
              "component": "richtext",
              "name": "title",
              "label": "Title",
              "valueType": "string",
              "description": "Enter main heading of the video"
            },
            {
              "component": "select",
              "name": "classes_titleRteFontSize",
              "label": "Title Font Size",
              "description": "Select the font size for the Title",
              "options": [
                { "name": "100px", "value": "title-fs-100px" },
                { "name": "60px", "value": "title-fs-60px" },
                { "name": "48px", "value": "title-fs-48px" },
                { "name": "36px", "value": "title-fs-36px" },
                { "name": "32px", "value": "title-fs-32px" },
                { "name": "28px", "value": "title-fs-28px" },
                { "name": "24px", "value": "title-fs-24px" },
                { "name": "20px", "value": "title-fs-20px" },
                { "name": "16px", "value": "title-fs-16px" },
                { "name": "14px", "value": "title-fs-14px" }
              ]
            },
            {
              "component": "select",
              "name": "classes_descriptionplacement",
              "label": "Description Placement",
              "description": "Select the appropriate position for Description placement on the left side of the viewport.",
              "value": "descriptionplacement-center",
              "options": [
                {
                  "name": "Top",
                  "value": "descriptionplacement-top"
                },
                {
                  "name": "Bottom",
                  "value": "descriptionplacement-bottom"
                },
                {
                  "name": "Center",
                  "value": "descriptionplacement-center"
                }
              ]
            },
            {
              "component": "richtext",
              "name": "description",
              "label": "Description",
              "valueType": "string",
              "description": "Enter description of the video"
            },
            {
              "component": "select",
              "name": "classes_descriptionRteFontSize",
              "label": "Description Font Size",
              "description": "Select the font size for the Description",
              "options": [
                { "name": "100px", "value": "description-fs-100px" },
                { "name": "60px", "value": "description-fs-60px" },
                { "name": "48px", "value": "description-fs-48px" },
                { "name": "36px", "value": "description-fs-36px" },
                { "name": "32px", "value": "description-fs-32px" },
                { "name": "28px", "value": "description-fs-28px" },
                { "name": "24px", "value": "description-fs-24px" },
                { "name": "20px", "value": "description-fs-20px" },
                { "name": "16px", "value": "description-fs-16px" },
                { "name": "14px", "value": "description-fs-14px" }
              ]
            }
          ]
        },
        {
          "component": "container",
          "name": "videoWithQuoteContainer",
          "label": "Video With Quote Fields",
          "valueType": "string",
          "condition": {
            "===": [
              {
                "var": "classes"
              },
              "video-quote"
            ]
          },
          "fields": [
            {
              "component": "checkbox-group",
              "label": "Quote Icon",
              "name": "quotrIcon",
              "valueType": "string",
              "description": "Select to display the quote icon",
              "options": [
                {
                  "name": "Quote Icon",
                  "value": "true"
                }
              ]
            },
            {
              "component": "richtext",
              "name": "quote",
              "label": "Quote",
              "valueType": "string",
              "description": "Enter the patient quote"
            },
            {
              "component": "select",
              "name": "classes_quoteRteFontSize",
              "label": "Quote Font Size",
              "description": "Select the font size for the Quote",
              "options": [
                { "name": "100px", "value": "quote-fs-100px" },
                { "name": "60px", "value": "quote-fs-60px" },
                { "name": "48px", "value": "quote-fs-48px" },
                { "name": "36px", "value": "quote-fs-36px" },
                { "name": "32px", "value": "quote-fs-32px" },
                { "name": "28px", "value": "quote-fs-28px" },
                { "name": "24px", "value": "quote-fs-24px" },
                { "name": "20px", "value": "quote-fs-20px" },
                { "name": "16px", "value": "quote-fs-16px" },
                { "name": "14px", "value": "quote-fs-14px" }
              ]
            },
            {
              "component": "richtext",
              "name": "patientName",
              "label": "Name",
              "valueType": "string",
              "description": "Enter the Patient name"
            },
            {
              "component": "select",
              "name": "classes_patientNameRteFontSize",
              "label": "Name Font Size",
              "description": "Select the font size for the Name",
              "options": [
                { "name": "100px", "value": "patientname-fs-100px" },
                { "name": "60px", "value": "patientname-fs-60px" },
                { "name": "48px", "value": "patientname-fs-48px" },
                { "name": "36px", "value": "patientname-fs-36px" },
                { "name": "32px", "value": "patientname-fs-32px" },
                { "name": "28px", "value": "patientname-fs-28px" },
                { "name": "24px", "value": "patientname-fs-24px" },
                { "name": "20px", "value": "patientname-fs-20px" },
                { "name": "16px", "value": "patientname-fs-16px" },
                { "name": "14px", "value": "patientname-fs-14px" }
              ]
            },
            {
              "component": "richtext",
              "name": "condition",
              "label": "Condition",
              "valueType": "string",
              "description": "Enter the Patient condition"
            },
            {
              "component": "select",
              "name": "classes_conditionRteFontSize",
              "label": "Condition Font Size",
              "description": "Select the font size for the Condition",
              "options": [
                { "name": "100px", "value": "condition-fs-100px" },
                { "name": "60px", "value": "condition-fs-60px" },
                { "name": "48px", "value": "condition-fs-48px" },
                { "name": "36px", "value": "condition-fs-36px" },
                { "name": "32px", "value": "condition-fs-32px" },
                { "name": "28px", "value": "condition-fs-28px" },
                { "name": "24px", "value": "condition-fs-24px" },
                { "name": "20px", "value": "condition-fs-20px" },
                { "name": "16px", "value": "condition-fs-16px" },
                { "name": "14px", "value": "condition-fs-14px" }
              ]
            }
          ]
        },
        {
          "component": "select",
          "name": "classes_ctacolor",
          "label": "CTA Color",
          "description": "Select the color for CTA Button Primary implies Green: #79DE00 Secondary implies White: #FFFFFF ",
          "value": "ctaColor-light",
          "options": [
            {
              "name": "Light",
              "value": "ctaColor-light"
            },
            {
              "name": "Dark",
              "value": "ctaColor-dark"
            }
          ]
        },
        {
          "component": "select",
          "name": "classes_ctastyle",
          "label": "CTA Style",
          "description": "Select the style of the Button CTA",
          "value": "ctaStyle-primary",
          "options": [
            {
              "name": "Primary",
              "value": "ctaStyle-primary"
            },
            {
              "name": "Secondary",
              "value": "ctaStyle-secondary"
            },
            {
              "name": "Neutral",
              "value": "ctaStyle-neutral"
            }
          ]
        },
        {
          "component": "select",
          "name": "classes_buttonctastyle",
          "label": "CTA Style",
          "description": "Select the style of the Button CTA",
          "value": "buttonctastyle-arrow",
          "options": [
            {
              "name": "Primary (Arrow)",
              "value": "buttonctastyle-arrow"
            },
            {
              "name": "Secondary (Play)",
              "value": "buttonctastyle-play"
            }
          ]
        },
        {
          "component": "text",
          "name": "video_videoPathStandardText",
          "label": "CTA Label",
          "valueType": "string",
          "description": "Enter label to display on the CTA",
          "value": "Watch now",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "classes"
              },
              "video-standard"
            ]
          }
        },
        {
          "component": "text",
          "name": "video_videoPathQuoteText",
          "label": "CTA Label",
          "valueType": "string",
          "description": "Enter label to display on the CTA",
          "value": "Watch patient story",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "classes"
              },
              "video-quote"
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "name": "video_videoPathStandard",
          "label": "Video Path",
          "description": "Upload the full-length video",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "classes"
              },
              "video-standard"
            ]
          }
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "name": "video_videoPathQuote",
          "label": "Video Path",
          "description": "Upload the full-length video",
          "required": true,
          "condition": {
            "===": [
              {
                "var": "classes"
              },
              "video-quote"
            ]
          }
        },
        {
          "component": "richtext",
          "name": "video_rte",
          "label": "Video Transcript",
          "required": true,
          "valueType": "string",
          "description": "Enter the video transcript"
        },
        {
          "component": "select",
          "name": "classes_rteRteFontSize",
          "label": "Video Transcript Font Size",
          "description": "Select the font size for the Video Transcript",
          "options": [
            { "name": "100px", "value": "transcript-fs-100px" },
            { "name": "60px", "value": "transcript-fs-60px" },
            { "name": "48px", "value": "transcript-fs-48px" },
            { "name": "36px", "value": "transcript-fs-36px" },
            { "name": "32px", "value": "transcript-fs-32px" },
            { "name": "28px", "value": "transcript-fs-28px" },
            { "name": "24px", "value": "transcript-fs-24px" },
            { "name": "20px", "value": "transcript-fs-20px" },
            { "name": "16px", "value": "transcript-fs-16px" },
            { "name": "14px", "value": "transcript-fs-14px" }
          ]
        }
      ]
    }
  ]
}
