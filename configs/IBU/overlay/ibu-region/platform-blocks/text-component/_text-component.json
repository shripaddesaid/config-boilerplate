                  {
                    "var": "oneButton|classes_ctatypefieldone"
                  },
                  "ctaType-button"
                ]
              },
              "options": [
                {
                  "name": "Primary",
                  "value": "ctaStyle-primary"
                },
                {
                  "name": "Secondary",
                  "value": "ctaStyle-secondary"
                },
                {
                  "name": "Neutral",
                  "value": "ctaStyle-neutral"
                }
              ]
            },
