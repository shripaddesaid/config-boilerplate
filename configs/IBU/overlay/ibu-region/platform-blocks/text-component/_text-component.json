          "component": "richtext",
          "name": "descriptionRte",
          "label": "Description",
          "valueType": "string",
          "description": "Enter description for additional context which can have styling such as Bold, italics and  ability to add text links."
        },
        {
          "component": "select",
          "name": "classes_descriptionRteFontSize",
          "label": "Description Font Size",
          "description": "Select the font size for the description",
          "options": [
            {
              "name": "100px",
              "value": "description-fs-100px"
            },
            {
              "name": "60px",
              "value": "description-fs-60px"
            },
            {
              "name": "48px",
              "value": "description-fs-48px"
            },
            {
              "name": "36px",
              "value": "description-fs-36px"
            },
            {
              "name": "32px",
