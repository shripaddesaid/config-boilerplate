          "component": "select",
          "name": "classes",
          "label": "Alignment",
          "description": "Select the alignment expected for entire block",
          "value": "alignment-left",
          "options": [
            {
              "name": "Left",
              "value": "alignment-left"
            },
            {
              "name": "Center",
              "value": "alignment-center"
            },
            {
              "name": "Right",
              "value": "alignment-right"
            }
          ]
        },
        {
          "component": "custom-asset-namespace:custom-asset",
          "configUrl": "/content/dam/custom-asset-picker/image.config.json",
          "valueType": "string",
          "name": "icon",
          "label": "Icon",
          "description": "Upload the icon image"
        },
        {
          "component": "custom-asset-namespace:custom-asset-mimetype",
          "valueType": "string",
          "name": "iconMimeType"
        },
        {
          "component": "text",
          "name": "iconAlt",
          "label": "Icon Alt text",
          "valueType": "string",
          "description": "Pick alt text from AEM DAM with ability to override it"
