                {
                  "name": "Link",
                  "value": "ctaSelection-link"
                },
                {
                  "name": "Asset (PDF/Image)",
                  "value": "ctaSelection-asset"
                }
              ]
            },
            {
              "component": "text",
              "name": "cta1LinkText",
              "label": "CTA Label",
              "valueType": "string",
