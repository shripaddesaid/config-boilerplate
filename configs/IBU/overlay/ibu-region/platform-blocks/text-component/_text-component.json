              "name": "100px",
              "value": "footnote-fs-100px"
            },
            {
              "name": "60px",
              "value": "footnote-fs-60px"
            },
            {
              "name": "48px",
              "value": "footnote-fs-48px"
            },
            {
              "name": "36px",
              "value": "footnote-fs-36px"
            },
            {
              "name": "32px",
              "value": "footnote-fs-32px"
            },
            {
              "name": "28px",
              "value": "footnote-fs-28px"
            },
            {
              "name": "24px",
              "value": "footnote-fs-24px"
            },
            {
              "name": "20px",
              "value": "footnote-fs-20px"
            },
            {
              "name": "16px",
              "value": "footnote-fs-16px"
            },
            {
              "name": "14px",
              "value": "footnote-fs-14px"
            }
          ]
        },
        {
          "component": "select",
          "name": "classes_ctaNumber",
          "label": "Number of CTA(s)",
          "description": "Select the number of CTA(s) required",
          "value": "ctaNumber-one",
          "options": [
            {
              "name": "One",
              "value": "ctaNumber-one"
            },
            {
              "name": "Two",
              "value": "ctaNumber-two"
            }
          ]
        },
        {
          "component": "container",
          "collapsible": true,
          "name": "oneButton",
          "label": "First Button CTA Fields",
          "valueType": "string",
          "fields": [
            {
              "component": "select",
              "name": "classes_ctatypefieldone",
              "label": "CTA Type",
              "description": "Select the type of CTA for component",
              "value": "ctaType-button",
              "options": [
                {
                  "name": "Button",
                  "value": "ctaType-button"
                },
                {
                  "name": "Text Link",
                  "value": "ctaType-textLink"
                }
              ]
            },
            {
              "component": "select",
              "name": "classes_ctacolorone",
              "label": "CTA Color",
              "description": "Select the color for CTA Button Primary implies Green: #79DE00 Secondary implies White: #FFFFFF ",
              "value": "ctaColor-light",
              "condition": {
                "===": [
                  {
                    "var": "oneButton|classes_ctatypefieldone"
                  },
                  "ctaType-button"
                ]
              },
              "options": [
                {
                  "name": "Light",
                  "value": "ctaColor-light"
                },
                {
                  "name": "Dark",
                  "value": "ctaColor-dark"
                }
